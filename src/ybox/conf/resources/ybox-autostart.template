# autostart desktop file for '{name}' ybox container
#
# Autogenerated by ybox-create {version} on {date}

[Desktop Entry]
Version=1.0
Name=ybox {name} container
Comment=Launch ybox {name} container
Exec=/bin/sh -c '. $HOME/.config/ybox/{env_file}; eval $YBOX_CONTAINER_MANAGER container rm {name} 2>/dev/null; eval $YBOX_CONTAINER_MANAGER run $CONTAINER_RUN_ARGS'
Terminal=false
Type=Application
